{
  "rewrites": [
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/blog/:post", "destination": "/blog/:post.html" },
    { "source": "/report", "destination": "/report.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/calculator", "destination": "/free-bazi-calculator.html" },
    { "source": "/free-bazi-calculator", "destination": "/free-bazi-calculator.html" },
    { "source": "/newsletter", "destination": "/newsletter.html" },
    { "source": "/api/referral/:action", "destination": "/api/referral" }
  ],
  "functions": {
    "api/referral.py": {
      "memory": 256,
      "maxDuration": 10
    }
  }
}
